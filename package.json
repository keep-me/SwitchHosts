{
  "private": true,
  "name": "switchhosts",
  "version": "5.0.0-beta.18",
  "description": "Switch hosts quickly!",
  "homepage": "https://switchhosts.vercel.app",
  "license": "Apache-2.0",
  "scripts": {
    "pretest": "rimraf ./test/tmp",
    "test": "vitest --config ./vitest.config.mts --watch=false",
    "typecheck": "tsc --noEmit",
    "clean:dist": "rimraf ./dist/*",
    "clean:build": "rimraf ./build/*",
    "dev:renderer": "vite --config ./vite.render.config.mts",
    "build:renderer": "vite build --config ./vite.render.config.mts",
    "build:renderer:tauri": "node scripts/sync-tauri-version.mjs && vite build --config ./vite.render.config.mts --outDir ../../build-tauri --emptyOutDir",
    "sort-lang": "node ./scripts/sort-lang.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:info": "tauri info",
    "version": "node scripts/sync-tauri-version.mjs && git add src/version.json src-tauri/tauri.conf.json"
  },
  "dependencies": {
    "dayjs": "1.11.19",
    "lodash": "4.17.23",
    "tslib": "2.8.1",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@mantine/core": "^8.3.16",
    "@mantine/hooks": "^8.3.16",
    "@mantine/notifications": "^8.3.16",
    "@tabler/icons-react": "3.38.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/assert": "1.5.11",
    "@types/lodash": "4.17.24",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "ahooks": "3.9.6",
    "clsx": "2.1.1",
    "codejar": "^4.3.0",
    "codejar-linenumbers": "^1.0.1",
    "jotai": "2.18.0",
    "prettier": "3.8.1",
    "pretty-bytes": "7.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "react-router": "7.13.1",
    "rimraf": "^6.1.3",
    "sass": "1.97.3",
    "smooth-scroll-into-view-if-needed": "2.0.2",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vite-plugin-static-copy": "3.3.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
